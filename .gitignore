# ── Secrets (NEVER commit) ─────────────────────────────────────────────
.env
*.env
!.env.example

# ── Personal data / PII ────────────────────────────────────────────────
# personal.yaml is committed so Railway deployments work without setup.
# master_resume.pdf is fetched at startup via RESUME_URL env var.
config/questions.yaml
config/master_resume.pdf
config/showcase.pdf
config/reference/
config/_backup_*/

# ── Generated output (resumes, cover letters, tracking, run state) ─────
# Keep the folder structure but ignore all generated content
outputs/**
!outputs/.gitkeep

# ── Python ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ── Virtual environments ──────────────────────────────────────────────
venv/
.venv/
env/

# ── Logs ───────────────────────────────────────────────────────────────
*.log
outputs/logs/

# ── Editors / OS ───────────────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
Thumbs.db

# ── Stray build artifacts ──────────────────────────────────────────────
for
D:ProjectsOneShotextension/
graphify-out/
