# ══════════════════════════════════════════════════════════════════════
#  OneShot — Environment Variables
#
#  LOCAL USE:  copy this file to .env and fill in your keys.
#  RAILWAY:    paste these into your Railway project → Variables tab.
#              Do NOT commit .env — it is gitignored.
# ══════════════════════════════════════════════════════════════════════

# ── Resume (Railway / cloud deployments) ──────────────────────────────
# Paste a public direct-download URL to your resume PDF.
# Google Drive: share the file → "Anyone with the link" → copy link
# then change: https://drive.google.com/file/d/FILE_ID/view
#          to: https://drive.google.com/uc?export=download&id=FILE_ID
RESUME_URL=

# ── LLM provider routing ──────────────────────────────────────────────
LLM_PROVIDER=gemini
LLM_PROVIDER_SMART=claude
LLM_PROVIDER_CHEAP=gemini
LLM_MODEL=claude-sonnet-4-6
LLM_MODEL_CHEAP=claude-haiku-4-5-20251001

# ── API keys (only need ONE provider minimum) ─────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Provider on/off ───────────────────────────────────────────────────
PROVIDER_GEMINI_ENABLED=true
PROVIDER_CLAUDE_ENABLED=true
PROVIDER_OPENAI_ENABLED=false

# ── Pipeline behaviour ────────────────────────────────────────────────
DRY_RUN=true
APPLIER_MODE=handoff
ATS_TARGET_MIN=70
ATS_MAX_REWRITES=2
CLAUDE_BUDGET_USD=20

# ── Daily rate limits per platform ────────────────────────────────────
DAILY_LIMIT_LINKEDIN=25
DAILY_LIMIT_INDEED=25
DAILY_LIMIT_OTHER=10

# ── LinkedIn login (optional) ─────────────────────────────────────────
LINKEDIN_USERNAME=
LINKEDIN_PASSWORD=

# ── Notion sync (optional) ────────────────────────────────────────────
NOTION_API_KEY=
NOTION_JOBS_DB_ID=
