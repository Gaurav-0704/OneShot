# --- LLM provider (only need ONE of these key sets) ---

# Default Claude two-tier (best quality)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI alternative
OPENAI_API_KEY=sk-...

# Free option: Gemini (1500 free requests/day)
GEMINI_API_KEY=AIza-your-gemini-key-here

# Provider routing
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-6              # smart-tier: resume + cover letter
LLM_MODEL_CHEAP=claude-haiku-4-5-20251001 # cheap-tier: parsing, scoring, audits, Q&A

# --- LinkedIn login (optional, leave blank to login manually each session) ---
LINKEDIN_USERNAME=
LINKEDIN_PASSWORD=

# --- Indeed / Glassdoor (optional) ---
INDEED_USERNAME=
INDEED_PASSWORD=

# --- Behavior toggles ---
DRY_RUN=true                   # set "false" to actually submit applications
PAUSE_BEFORE_SUBMIT=true       # ask before clicking final submit each time
DAILY_LIMIT_LINKEDIN=25
DAILY_LIMIT_INDEED=50
DAILY_LIMIT_OTHER=20

# --- Notion (optional, for logging) ---
NOTION_API_KEY=
NOTION_JOBS_DB_ID=
