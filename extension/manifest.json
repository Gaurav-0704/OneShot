{
  "manifest_version": 3,
  "name": "OneShot Copilot",
  "version": "0.1.0",
  "description": "Reads the focused application question and sends it to your local OneShot server for an AI-generated answer.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:5001/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "OneShot Copilot"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://jobs.ashbyhq.com/*",
        "https://*.workday.com/*",
        "https://apply.workable.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
